{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "npm --prefix .. run build -w shared",
    "predev": "npm --prefix .. run build -w shared",
    "dev": "node scripts/validate-jwt.js && nest start --watch",
    "start": "node scripts/validate-jwt.js && node dist/src/main.js",
    "build": "nest build",
    "test": "tsx --test \"src/**/*.spec.ts\"",
    "format": "prettier --check \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "lint": "eslint \"src/**/*.ts\"",
    "db:validate": "tsx scripts/validate-db.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "validate-jwt": "node scripts/validate-jwt.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "shared": "file:../shared"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
