{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm --prefix .. run build -w shared",
    "predev": "npm --prefix .. run build -w shared",
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "axios": "^1.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.3",
    "shared": "file:../shared"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
